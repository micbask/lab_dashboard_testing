# ─────────────────────────────────────────────────────────────────────────
# scripts/.env — credentials for scripts/email_ingest.py
#
# Copy this file to .env in the same directory and fill in the values.
# DO NOT commit .env — scripts/.gitignore already excludes it.
#
# Mail fetching is handled entirely by scripts/fetch_attachment.applescript
# against Apple Mail, so no mailbox credentials live in this file.
# ─────────────────────────────────────────────────────────────────────────

# GitHub target repo (used by storage.ingest_new_data via the Contents API)
# Token needs contents:write on the repo below.
GITHUB_TOKEN=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
GITHUB_REPOSITORY=micbask/lab_dashboard_testing

# Optional: override the drop folder the AppleScript writes into and the
# Python script reads from. Leave blank to use the default hardcoded in
# both files:
#   /Users/michaelbask/Library/CloudStorage/OneDrive-KeckMedicineofUSC/Work/Productivity Heat Maps/xls_ingest
# DROP_FOLDER=

# Optional: override log file path
