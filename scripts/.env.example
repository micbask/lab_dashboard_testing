# ─────────────────────────────────────────────────────────────────────────
# scripts/.env — credentials for scripts/email_ingest.py
#
# Copy this file to .env in the same directory and fill in the values.
# DO NOT commit .env — add it to .gitignore (the repo's .gitignore should
# already exclude scripts/.env).
# ─────────────────────────────────────────────────────────────────────────

# Exchange / Outlook mailbox (Basic Auth)
EXCHANGE_EMAIL=you@usc.edu
EXCHANGE_USERNAME=you@usc.edu
EXCHANGE_PASSWORD=your-password-or-app-password
# Optional: leave blank to use Autodiscover. For Office 365 use:
#   outlook.office365.com
EXCHANGE_SERVER=

# Email filter criteria
SENDER_EMAIL=reports@lab-vendor.example.com
SUBJECT_KEYWORD=All Labs

# GitHub target repo (used by storage.ingest_new_data via the Contents API)
# Token needs contents:write on the repo below.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPOSITORY=micbask/lab_dashboard_testing

# Optional: override log file path
# LOG_FILE=/Users/you/Library/Logs/lab-dashboard-ingest.log
